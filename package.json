{
	"name": "bpsr-logs",
	"version": "0.1.0",
	"description": "",
	"type": "module",
	"packageManager": "bun@1.3.11",
	"scripts": {
		"build": "bun run --bun vite build",
		"check": "bun run --bun svelte-kit sync && bun run --bun svelte-check --tsconfig ./tsconfig.json && cargo check --manifest-path src-tauri/Cargo.toml",
		"check:watch": "bun run --bun svelte-kit sync && bun run --bun svelte-check --tsconfig ./tsconfig.json --watch",
		"clean": "cargo clean --manifest-path src-tauri/Cargo.toml",
		"dev": "bun run --bun svelte-kit sync && bun run --bun vite dev",
		"format": "prettier --write . && cargo fmt --manifest-path src-tauri/Cargo.toml",
		"format:check": "prettier --check . && cargo fmt --check --manifest-path src-tauri/Cargo.toml",
		"lint": "eslint .",
		"preview": "vite preview",
		"tauri": "tauri",
		"update": "cargo update --manifest-path src-tauri/Cargo.toml",
		"upgrade": "ncu -u && bun install && cargo install cargo-edit && cargo upgrade --incompatible allow --manifest-path src-tauri/Cargo.toml && cargo update --manifest-path src-tauri/Cargo.toml"
	},
	"license": "MIT",
	"dependencies": {
		"@tanstack/table-core": "^8.21.3",
		"@tauri-apps/api": "^2.10.1",
		"@tauri-apps/plugin-autostart": "^2.5.1",
		"@tauri-apps/plugin-clipboard-manager": "^2.3.2",
		"@tauri-apps/plugin-global-shortcut": "^2.3.1",
		"@tauri-apps/plugin-opener": "^2.5.3",
		"@tauri-apps/plugin-os": "^2.3.2",
		"@tauri-apps/plugin-store": "^2.4.2",
		"@tauri-apps/plugin-updater": "^2.10.1",
		"@tauri-store/svelte": "^3.2.0",
		"html2canvas-pro": "^2.0.2",
		"tippy.js": "^6.3.7"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.4",
		"@eslint/js": "^10.0.1",
		"@iconify-json/logos": "^1.2.11",
		"@iconify-json/lucide": "^1.2.101",
		"@iconify/json": "^2.2.459",
		"@internationalized/date": "^3.12.0",
		"@lucide/svelte": "^1.7.0",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.56.1",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/vite": "^4.2.2",
		"@tauri-apps/cli": "^2.10.1",
		"@types/node": "^25.5.2",
		"bits-ui": "^2.17.2",
		"clsx": "^2.1.1",
		"eslint": "^10.2.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.0",
		"formsnap": "^2.0.1",
		"globals": "^17.4.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte": "^5.55.1",
		"svelte-check": "^4.4.6",
		"svelte-eslint-parser": "^1.6.0",
		"sveltekit-superforms": "^2.30.1",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.2.2",
		"tw-animate-css": "^1.4.0",
		"typescript": "~6.0.2",
		"typescript-eslint": "^8.58.0",
		"unplugin-icons": "^23.0.1",
		"vite": "^8.0.3"
	}
}
